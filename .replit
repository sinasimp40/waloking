modules = ["nodejs-20", "web"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[[ports]]
localPort = 4231
externalPort = 80

[[ports]]
localPort = 4232
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m http.server 5000 --directory walok/update-server/public --bind 0.0.0.0"
waitForPort = 5000

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
