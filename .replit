modules = ["nodejs-24"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[[ports]]
localPort = 4231
externalPort = 80

[[ports]]
localPort = 4232
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd walok/update-server && OTA_ADMIN_PASSWORD=test123 OTA_JWT_SECRET=devsecret OTA_PORT=5000 OTA_HOST=0.0.0.0 node server.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
